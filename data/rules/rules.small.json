      "theme": "self_preservation",
      "priority": 100,
      "match": {
        "max_health": 4,
        "required_context_tags": ["branching_path"]
      },
      "preferred_option_tags": ["safe"],
      "forbidden_option_tags": ["volatile", "occult", "high_risk"],
      "sanity_penalty": 2,
      "narration_keys": ["opening_self_preservation", "judgement_default", "warning_default"],
      "notes": "Crossroads rule for low-health or frayed states. It pushes the player away from obvious escalation."
    },
    {
      "id": "rule_temptation_hold_composure",
      "name": "When temptation crowds the table, keep your hands steady",
      "decision_types": ["whisper_offer", "artifact_offer", "market_offer", "omens_choice"],
      "theme": "composure",
      "priority": 90,
      "match": {
        "required_context_tags": ["temptation"]
      },
      "preferred_option_tags": ["safe", "restraint", "grounded"],
      "forbidden_option_tags": ["greedy", "luxury", "occult"],
      "sanity_penalty": 1,
      "narration_keys": ["opening_composure", "judgement_default", "warning_default"],
      "notes": "General temptation rule. It rewards restraint and reduces mentally costly overreach."
    },
    {
      "id": "rule_branching_preserve_clarity",
      "name": "When the path splits, choose what keeps the picture clear",
      "decision_types": ["crossroads", "omens_choice"],
      "theme": "clarity",
