{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Arbitration",
  "type": "object",
  "required": ["arbitration_id", "context", "options"],
  "properties": {
    "arbitration_id": { "type": "string" },
    "context": {
      "type": "object",
      "required": ["context_id", "scene_type", "floor", "resources"],
      "properties": {
        "context_id": { "type": "string" },
        "scene_type": {
          "type": "string",
          "enum": ["run", "crossroads", "whisper_offer", "artifact_offer", "market_offer", "omens_choice"]
        },
        "floor": { "type": "integer", "minimum": 0 },
        "act": { "type": "integer", "minimum": 1 },
        "resources": {
          "type": "object",
          "properties": {
            "health": { "type": "integer", "minimum": 0 },
            "max_health": { "type": "integer", "minimum": 1 },
            "money": { "type": "integer", "minimum": 0 },
            "sanity": { "type": "integer", "minimum": 0 }
          },
          "additionalProperties": true
        },
        "tags": {
          "type": "array",
          "items": { "type": "string" }
        },
        "metadata": { "type": "object" }
      },
      "additionalProperties": false
    },
    "options": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["option_id", "label", "tags"],
        "properties": {
          "option_id": { "type": "string" },
          "label": { "type": "string" },
          "tags": {
            "type": "array",
            "items": { "type": "string" }
          },
          "metadata": { "type": "object" }
        },
        "additionalProperties": false
      }
    },
    "metadata": { "type": "object" }
  },
  "additionalProperties": false
}
