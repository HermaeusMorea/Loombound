{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "RunSnapshot",
  "type": "object",
  "required": [
    "arbitration_id",
    "selected_rule_id",
    "matched_rule_ids",
    "theme_scores",
    "option_results",
    "sanity_delta"
  ],
  "properties": {
    "arbitration_id": { "type": "string" },
    "selected_rule_id": { "type": ["string", "null"] },
    "matched_rule_ids": {
      "type": "array",
      "items": { "type": "string" }
    },
    "theme_scores": {
      "type": "object",
      "additionalProperties": { "type": "number" }
    },
    "option_results": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["option_id", "label", "verdict", "reasons", "sanity_cost"],
        "properties": {
          "option_id": { "type": "string" },
          "label": { "type": "string" },
          "verdict": { "type": "string", "enum": ["stable", "destabilizing"] },
          "reasons": {
            "type": "array",
            "items": { "type": "string" }
          },
          "sanity_cost": { "type": "integer", "minimum": 0 }
        },
        "additionalProperties": false
      }
    },
    "sanity_delta": { "type": "integer", "minimum": 0 },
    "narration": {
      "type": "object",
      "properties": {
        "opening": { "type": "string" },
        "judgement": { "type": "string" },
        "warning": { "type": "string" }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
