{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ChoiceContext",
  "type": "object",
  "required": ["context_id", "decision_type", "floor", "resources", "options"],
  "properties": {
    "context_id": { "type": "string" },
    "decision_type": {
      "type": "string",
      "enum": ["map_routing", "card_reward", "shop", "relic_choice", "event_branch"]
    },
    "floor": { "type": "integer", "minimum": 0 },
    "act": { "type": "integer", "minimum": 1 },
    "resources": {
      "type": "object",
      "properties": {
        "gold": { "type": "integer", "minimum": 0 },
        "hp_ratio": { "type": "number", "minimum": 0, "maximum": 1 }
      },
      "additionalProperties": true
    },
    "tags": {
      "type": "array",
      "items": { "type": "string" }
    },
    "options": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["option_id", "label", "tags"],
        "properties": {
          "option_id": { "type": "string" },
          "label": { "type": "string" },
          "tags": {
            "type": "array",
            "items": { "type": "string" }
          },
          "metadata": { "type": "object" }
        },
        "additionalProperties": false
      }
    },
    "metadata": { "type": "object" }
  },
  "additionalProperties": false
}

