#!/usr/bin/env bash
# loombound — unified CLI for Loombound
#
# SUBCOMMANDS
#   arc-palette  [--count N] [--output PATH]
#       Generate the A2 cache (global arc-state palette). One-time setup.
#
#   clean-palette
#       Delete data/a2_cache_table.json.
#
#   gen "theme" [--nodes N] [--lang zh] [--tone "..."] [--worldview "..."]
#               [--model PROVIDER[:MODEL]] [--skip-t1-cache]
#       Generate a saga graph (Opus) + A1 cache skeletons (Haiku).
#
#   run [--saga ID_OR_PATH] [--fast MODEL] [--lang zh] [--nodes N]
#       Launch the game. Requires ANTHROPIC_API_KEY (Claude API only).
#
#   report [--campaign ID]
#       Print LLM usage / cost report for the last run.
#
#   clean [--saga ID_OR_PATH] [--all]
#       Remove saga JSON and node files. Keeps data/a2_cache_table.json.
#       --saga : remove only that saga's files
#       --all (or no flag) : remove ALL sagas and node directories
#
#   clean-logs
#       Truncate logs/llm.md to empty.
#
# EXAMPLES
#   ./loombound arc-palette
#   ./loombound gen "亚南猎人之夜" --nodes 4 --lang zh --tone "哥特克苏鲁"
#   ./loombound run --lang zh
#   ./loombound run --saga hunters_night_yharnam_last_lucid --lang zh
#   ./loombound report
#   ./loombound clean --saga wall_street_undercurrent_act1
#   ./loombound clean --all
#   ./loombound clean-logs

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
cd "$SCRIPT_DIR"

if [[ -f ".env" ]]; then
    set -a
    source .env
    set +a
fi

PYTHON="$SCRIPT_DIR/.venv/bin/python"
DATA_DIR="$SCRIPT_DIR/data"

# ---------------------------------------------------------------------------
# Helpers
# ---------------------------------------------------------------------------

_die() { echo "loombound: $*" >&2; exit 1; }

_usage() {
    sed -n '2,38p' "$0"
    exit 0
}

# Resolve a campaign ID or path to a JSON file path.
# Accepts: bare ID, data/campaigns/ID.json, or absolute path.
_resolve_campaign() {
    local id="$1"
    if [[ "$id" == /* ]] || [[ "$id" == ./* ]]; then
        echo "$id"
    elif [[ "$id" == data/sagas/* ]]; then
        echo "$SCRIPT_DIR/$id"
    else
        echo "$DATA_DIR/sagas/${id%.json}.json"
    fi
}

# ---------------------------------------------------------------------------
# Subcommand dispatch
# ---------------------------------------------------------------------------

[[ $# -eq 0 ]] && _usage

subcmd="$1"; shift

case "$subcmd" in

    # ── arc-palette ─────────────────────────────────────────────────────────
    arc-palette)
        exec "$PYTHON" -m src.t3.core.gen_a2_cache_table "$@"
        ;;

    # ── clean-palette ────────────────────────────────────────────────────────
    clean-palette)
        target="$DATA_DIR/a2_cache_table.json"
        if [[ -f "$target" ]]; then
            rm "$target"
            echo "Deleted $target"
        else
            echo "Nothing to clean — $target does not exist."
        fi
        ;;

    # ── clean-logs ───────────────────────────────────────────────────────────
    clean-logs)
        log_file="$SCRIPT_DIR/logs/llm.md"
        if [[ -f "$log_file" ]]; then
            > "$log_file"
            echo "Cleared $log_file"
        else
            echo "Nothing to clean — $log_file does not exist."
        fi
        ;;

    # ── gen ─────────────────────────────────────────────────────────────────
    gen)
        provider=""
        provider_model=""
        passthrough=()

        while [[ $# -gt 0 ]]; do
            case "$1" in
                --model)
                    val="$2"; shift 2
                    if [[ "$val" == *:* ]]; then
                        provider="${val%%:*}"
                        provider_model="${val#*:}"
                    else
                        provider="$val"
                    fi
                    ;;
                *) passthrough+=("$1"); shift ;;
            esac
        done

        [[ -n "$provider" ]]       && passthrough+=(--provider "$provider")
        [[ -n "$provider_model" ]] && passthrough+=(--provider-model "$provider_model")

        exec "$PYTHON" -m src.t3.core.generate_campaign "${passthrough[@]+"${passthrough[@]}"}"
        ;;

    # ── run ─────────────────────────────────────────────────────────────────
    run)
        fast_model=""
        passthrough=()

        while [[ $# -gt 0 ]]; do
            case "$1" in
                --fast)
                    fast_model="$2"; shift 2
                    ;;
                --saga)
                    passthrough+=(--saga "$(_resolve_campaign "$2")"); shift 2
                    ;;
                *) passthrough+=("$1"); shift ;;
            esac
        done

        py_args=("${passthrough[@]+"${passthrough[@]}"}")
        [[ -n "$fast_model" ]] && py_args+=(--fast "$fast_model")

        exec "$PYTHON" -m src.runtime.play_cli "${py_args[@]+"${py_args[@]}"}"
        ;;

    # ── report ───────────────────────────────────────────────────────────────
    report)
        exec "$PYTHON" scripts/report_llm_usage.py "$@"
        ;;

    # ── clean ────────────────────────────────────────────────────────────────
    clean)
        saga_id=""
        clean_all=0

        while [[ $# -gt 0 ]]; do
            case "$1" in
                --saga) saga_id="$2"; shift 2 ;;
                --all)  clean_all=1; shift ;;
                *) _die "clean: unknown flag '$1'" ;;
            esac
        done

        if [[ -n "$saga_id" ]]; then
            # Remove a single saga
            campaign_file="$(_resolve_campaign "$saga_id")"
            saga_stem="${saga_id%.json}"
            saga_stem="${saga_stem##*/}"           # basename without .json
            nodes_dir="$DATA_DIR/waypoints/$saga_stem"
            removed=0

            if [[ -f "$campaign_file" ]]; then
                rm "$campaign_file"
                echo "Removed $campaign_file"
                removed=1
            fi
            if [[ -d "$nodes_dir" ]]; then
                rm -rf "$nodes_dir"
                echo "Removed $nodes_dir/"
                removed=1
            fi
            [[ $removed -eq 0 ]] && echo "Nothing to clean for saga '$saga_stem'."

        else
            # Remove all sagas and node directories (keep A2 cache + rules/text)
            echo "Cleaning all saga data (keeping data/a2_cache_table.json)..."
            removed=0

            for f in "$DATA_DIR/sagas/"*.json; do
                [[ -f "$f" ]] || continue
                rm "$f"
                echo "  Removed $f"
                removed=1
            done

            for d in "$DATA_DIR/waypoints/"/*/; do
                [[ -d "$d" ]] || continue
                rm -rf "$d"
                echo "  Removed $d"
                removed=1
            done

            [[ $removed -eq 0 ]] && echo "Nothing to clean."
            [[ $removed -eq 1 ]] || echo "Done."
        fi
        ;;

    # ── help / unknown ───────────────────────────────────────────────────────
    help|--help|-h)
        _usage
        ;;
    *)
        echo "loombound: unknown subcommand '$subcmd'" >&2
        echo "Run './loombound --help' for usage." >&2
        exit 1
        ;;
esac
