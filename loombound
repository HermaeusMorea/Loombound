#!/usr/bin/env bash
# loombound — thin wrapper: find Python/venv, then hand off to src.loombound_main

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

if [[ -n "${VIRTUAL_ENV:-}" ]] && [[ -x "$VIRTUAL_ENV/bin/python" ]]; then
    PYTHON="$VIRTUAL_ENV/bin/python"
elif [[ -x "$SCRIPT_DIR/.venv/bin/python" ]]; then
    PYTHON="$SCRIPT_DIR/.venv/bin/python"
elif command -v python3 &>/dev/null; then
    PYTHON="$(command -v python3)"
else
    echo "loombound: No Python found. Set up a virtualenv: python3 -m venv .venv && .venv/bin/pip install -e ." >&2
    exit 1
fi

cd "$SCRIPT_DIR"
exec "$PYTHON" -m src.loombound_main "$@"
